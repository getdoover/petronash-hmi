{
    "petronash_hmi": {
        "name": "petronash_hmi",
        "display_name": "Petronash HMI",
        "type": "PRO",
        "visibility": "PUB",
        "allow_many": true,
        "description": "Petronash local HMI for SIA pump skids (Aramco) - read-only panel showing pump states, flow/pressure/tank readings, alarm setpoints and volume totaliser",
        "long_description": "README.md",
        "depends_on": [],
        "owner_org_key": "36a22e32-ab81-4a39-b400-869d532a052d",
        "image_name": null,
        "container_registry_profile_id": null,
        "build_args": null,
        "config_schema": {
            "$schema": "https://json-schema.org/draft/2020-12/schema",
            "$id": "",
            "title": "$default",
            "type": "object",
            "properties": {
                "flow_sensor_app": {
                    "title": "Flow Sensor App",
                    "x-name": "flow_sensor_app",
                    "x-hidden": true,
                    "format": "doover-resource-application",
                    "type": [
                        "string",
                        "null"
                    ],
                    "x-required": false,
                    "description": "The 4-20mA sensor application measuring flow rate",
                    "default": "4_20ma_sensor_1",
                    "x-position": 0
                },
                "pressure_sensor_app": {
                    "title": "Pressure Sensor App",
                    "x-name": "pressure_sensor_app",
                    "x-hidden": true,
                    "format": "doover-resource-application",
                    "type": [
                        "string",
                        "null"
                    ],
                    "x-required": false,
                    "description": "The 4-20mA sensor application measuring pressure",
                    "default": "4_20ma_sensor_2",
                    "x-position": 1
                },
                "tank_level_app": {
                    "title": "Tank Level App",
                    "x-name": "tank_level_app",
                    "x-hidden": true,
                    "format": "doover-resource-application",
                    "type": [
                        "string",
                        "null"
                    ],
                    "x-required": false,
                    "description": "The analog level sensor application measuring tank level",
                    "default": "analog_level_sensor_1",
                    "x-position": 2
                },
                "pump_controller_app": {
                    "title": "Pump Controller App",
                    "x-name": "pump_controller_app",
                    "x-hidden": true,
                    "format": "doover-resource-application",
                    "type": [
                        "string",
                        "null"
                    ],
                    "x-required": false,
                    "description": "The Petronash pump controller application (pump states, volume totaliser and alerts)",
                    "default": "petronash_pump_controller_1",
                    "x-position": 3
                },
                "display_units": {
                    "enum": [
                        "Inch (\")",
                        "Millimeter (mm)"
                    ],
                    "title": "Display Units",
                    "x-name": "display_units",
                    "x-hidden": false,
                    "type": [
                        "string",
                        "null"
                    ],
                    "x-required": false,
                    "description": "Units used for length readings (e.g. tank level) on the screen",
                    "default": "Inch (\")",
                    "x-position": 4
                },
                "dv_proc_subscriptions": {
                    "title": "Subscription",
                    "x-name": "dv_proc_subscriptions",
                    "x-hidden": false,
                    "type": [
                        "array",
                        "null"
                    ],
                    "x-required": false,
                    "description": "A list of channels to subscribe to.",
                    "default": [],
                    "x-position": 5,
                    "items": {
                        "title": "Channel Subscription",
                        "x-name": "dv_proc_subscription",
                        "x-hidden": false,
                        "type": "string",
                        "x-required": true,
                        "description": "The name of the channel to subscribe to"
                    }
                }
            },
            "additionalElements": true,
            "required": []
        },
        "key": "",
        "code_repo_key": null,
        "repo_branch": "main",
        "staging_config": {
            "id": 202276888423479815,
            "lambda_config": {
                "Environment": {
                    "Variables": {
                        "DOOVER_DATA_ENDPOINT": "https://data.staging.udoover.com/api"
                    }
                },
                "Runtime": "python3.13",
                "Timeout": 300,
                "Handler": "src.petronash_hmi.handler",
                "MemorySize": 256
            }
        },
        "ui_schema": {
            "displayString": "$config.app().APP_DISPLAY_NAME",
            "hidden": "$config.app().hidden:boolean:false:boolean:false",
            "position": "$config.app().dv_app_position:number:0",
            "icon": null,
            "colour": null,
            "defaultOpen": "$config.app().dv_app_default_open:boolean:true",
            "type": "uiApplication",
            "name": "$config.app().APP_KEY",
            "children": {
                "petronash_hmi_widget": {
                    "name": "petronash_hmi_widget",
                    "type": "uiRemoteComponent",
                    "displayString": "Petronash HMI",
                    "showActivity": true,
                    "componentUrl": "$config.app().dv_widget_url",
                    "position": 51,
                    "hidden": false,
                    "children": {},
                    "scope": "PetronashHmiWidget",
                    "module": "./PetronashHmiWidget",
                    "app_key": "$config.app().APP_KEY"
                }
            }
        },
        "build_widget_command": "npm --prefix widget run build",
        "widget": "widget/assets/PetronashHmiWidget.js",
        "organisation_id": null,
        "id": 202285986707717380,
        "owner_org_id": null,
        "code_repo_id": null,
        "lambda_config": {
            "Runtime": "python3.13",
            "Timeout": 300,
            "MemorySize": 256,
            "Handler": "src.petronash_hmi.handler"
        },
        "icon_url": null,
        "banner_url": null,
        "export_config_command": null,
        "export_ui_command": null,
        "generate_ui": true,
        "run_command": null,
        "lambda_arn": null
    }
}